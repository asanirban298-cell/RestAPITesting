{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "unitId": { "type": "string", "pattern": "^[A-Z]{1}[0-9]{9}$" }, 
    "bloodType": { 
      "type": "string", 
      "enum": ["O-POS", "O-NEG", "A-POS", "A-NEG", "B-POS", "B-NEG", "AB-POS", "AB-NEG"] 
    },
    "volume_ml": { "type": "integer", "minimum": 200, "maximum": 600 },
    "isCrossMatched": { "type": "boolean" }
  },
  "required": ["unitId", "bloodType", "isCrossMatched"]
}